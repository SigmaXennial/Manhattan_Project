{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Manhattan Project: Main Console (bot.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/bot.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Manhattan Project: Search Agent",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/search_agent.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Manhattan Project: Master Investigator",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/master_investigator.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        }
    ]
}
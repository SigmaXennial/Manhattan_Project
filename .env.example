# Manhattan Project - Environment Variables Template
# Copy this file to .env and replace placeholder values with your real credentials.
# The .env file is gitignored and will never be committed to the repository.

# --- Required: Tavily API Key ---
# Used by master_investigator.py and search_agent.py for structured web search.
# Obtain your key at: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
